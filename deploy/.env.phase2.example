# ==========================================
# Babylon Phase 2 — Local Alienware Hosting
# ==========================================

# Storage — local disk
LOCAL_MEDIA_PATH=D:/Babylon/media

# API
PORT=3000
DATABASE_URL=file:D:/Babylon/data/babylon.db
BABYLON_PIN=
ALLOWED_ORIGINS=http://localhost:3001,http://192.168.1.100:3001

# Metadata (unchanged from Phase 1)
TMDB_API_KEY=<your-tmdb-api-key>
TMDB_READ_ACCESS_TOKEN=<your-tmdb-read-access-token>

# Ingest daemon (WSL2 paths)
LOCAL_MEDIA_PATH=/mnt/d/Babylon/media
DOWNLOAD_DIR=/mnt/d/Babylon/downloads/raw
PROCESSED_DIR=/mnt/d/Babylon/downloads/processed
INGEST_STATE_DIR=/mnt/d/Babylon/app/ingest
INGEST_POLL_INTERVAL=300
BABYLON_API_URL=http://localhost:3000
BABYLON_PIN=

# qBittorrent
QBITTORRENT_HOST=http://localhost:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=<your-password>
